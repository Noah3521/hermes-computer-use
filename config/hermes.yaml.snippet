# Paste into your ~/.hermes/config.yaml under `mcp_servers:`
# Replace the paths if you cloned this repo somewhere other than ~/hermes-computer-use.

mcp_servers:
  computer_use:
    command: /home/geunuk/.hermes/hermes-agent/venv/bin/python
    args:
      - /home/geunuk/hermes-computer-use/computer_use_mcp.py
    env:
      CU_DISPLAY: "99"
      CU_WIDTH: "1440"
      CU_HEIGHT: "900"
      CU_STATE_DIR: /tmp/hermes-computer-use
    connect_timeout: 60
    timeout: 120
